{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://narracut.dev/schemas/contracts/v1/narracut-contracts-v1.schema.json",
  "title": "NarraCutContractDocument",
  "description": "NarraCut v1 portable project and execution contracts.",
  "oneOf": [
    { "$ref": "#/$defs/Project" },
    { "$ref": "#/$defs/StageDefinition" },
    { "$ref": "#/$defs/StageConfig" },
    { "$ref": "#/$defs/StageExecutionSnapshot" },
    { "$ref": "#/$defs/JobDefinition" },
    { "$ref": "#/$defs/StageRun" },
    { "$ref": "#/$defs/Artifact" },
    { "$ref": "#/$defs/ReviewRecord" },
    { "$ref": "#/$defs/JobEvent" },
    { "$ref": "#/$defs/RenderManifest" }
  ],
  "$defs": {
    "SchemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "JsonObject": {
      "type": "object",
      "additionalProperties": true
    },
    "StageStatus": {
      "type": "string",
      "enum": [
        "draft",
        "ready",
        "running",
        "needs_review",
        "approved",
        "failed",
        "stale"
      ]
    },
    "StageRunStatus": {
      "type": "string",
      "enum": ["queued", "running", "succeeded", "failed", "canceled"]
    },
    "JobStatus": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "retrying",
        "succeeded",
        "failed",
        "canceled"
      ]
    },
    "MutableStageState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stageId", "status", "staleBecauseStageIds"],
      "properties": {
        "stageId": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["draft", "ready", "running", "needs_review", "failed"]
        },
        "approvedRunId": { "type": "string" },
        "latestRunId": { "type": "string" },
        "staleBecauseStageIds": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 0
        }
      }
    },
    "ApprovedStageState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stageId",
        "status",
        "approvedRunId",
        "latestRunId",
        "staleBecauseStageIds"
      ],
      "properties": {
        "stageId": { "type": "string" },
        "status": { "type": "string", "const": "approved" },
        "approvedRunId": { "type": "string" },
        "latestRunId": { "type": "string" },
        "staleBecauseStageIds": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 0
        }
      }
    },
    "StaleStageState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stageId",
        "status",
        "approvedRunId",
        "latestRunId",
        "staleBecauseStageIds"
      ],
      "properties": {
        "stageId": { "type": "string" },
        "status": { "type": "string", "const": "stale" },
        "approvedRunId": { "type": "string" },
        "latestRunId": { "type": "string" },
        "staleBecauseStageIds": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "StageState": {
      "oneOf": [
        { "$ref": "#/$defs/MutableStageState" },
        { "$ref": "#/$defs/ApprovedStageState" },
        { "$ref": "#/$defs/StaleStageState" }
      ]
    },
    "Project": {
      "title": "Project",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "documentType",
        "projectFormatVersion",
        "projectId",
        "name",
        "workflowDefinitionId",
        "stages",
        "createdAt",
        "updatedAt",
        "metadata"
      ],
      "properties": {
        "schemaVersion": { "$ref": "#/$defs/SchemaVersion" },
        "documentType": { "type": "string", "const": "project" },
        "projectFormatVersion": { "type": "integer", "const": 1 },
        "projectId": { "type": "string" },
        "name": { "type": "string", "minLength": 1 },
        "workflowDefinitionId": { "type": "string" },
        "defaultLocale": { "type": "string" },
        "stages": {
          "type": "array",
          "items": { "$ref": "#/$defs/StageState" }
        },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "metadata": { "$ref": "#/$defs/JsonObject" }
      }
    },
    "StageDefinition": {
      "title": "StageDefinition",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "documentType",
        "stageId",
        "definitionVersion",
        "title",
        "description",
        "dependencies",
        "inputKinds",
        "outputKinds",
        "configSchemaRef",
        "requiresApprovedInputs",
        "supportsPartialRegeneration"
      ],
      "properties": {
        "schemaVersion": { "$ref": "#/$defs/SchemaVersion" },
        "documentType": {
          "type": "string",
          "const": "stage_definition"
        },
        "stageId": { "type": "string" },
        "definitionVersion": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "inputKinds": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "outputKinds": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "configSchemaRef": { "type": "string" },
        "requiresApprovedInputs": { "type": "boolean" },
        "supportsPartialRegeneration": { "type": "boolean" }
      }
    },
    "DecisionRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decisionId", "key", "value", "madeBy", "madeAt"],
      "properties": {
        "decisionId": { "type": "string" },
        "key": { "type": "string" },
        "value": true,
        "rationale": { "type": "string" },
        "madeBy": { "type": "string" },
        "madeAt": { "type": "string" }
      }
    },
    "StageConfig": {
      "title": "StageConfig",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "documentType",
        "configId",
        "projectId",
        "stageId",
        "revision",
        "values",
        "decisions",
        "updatedAt"
      ],
      "properties": {
        "schemaVersion": { "$ref": "#/$defs/SchemaVersion" },
        "documentType": { "type": "string", "const": "stage_config" },
        "configId": { "type": "string" },
        "projectId": { "type": "string" },
        "stageId": { "type": "string" },
        "revision": { "type": "integer", "minimum": 1 },
        "values": { "$ref": "#/$defs/JsonObject" },
        "decisions": {
          "type": "array",
          "items": { "$ref": "#/$defs/DecisionRecord" }
        },
        "updatedAt": { "type": "string" }
      }
    },
    "ArtifactInputReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "refId",
        "referenceType",
        "kind",
        "contentHash",
        "artifactId",
        "sourceRunId",
        "reviewRecordId",
        "claimIds",
        "evidenceRefs"
      ],
      "properties": {
        "refId": { "type": "string" },
        "referenceType": { "type": "string", "const": "artifact" },
        "kind": { "type": "string" },
        "contentHash": { "type": "string" },
        "artifactId": { "type": "string" },
        "sourceRunId": { "type": "string" },
        "reviewRecordId": { "type": "string" },
        "claimIds": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "evidenceRefs": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    },
    "ProjectDocumentInputReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "refId",
        "referenceType",
        "kind",
        "contentHash",
        "uri",
        "claimIds",
        "evidenceRefs"
      ],
      "properties": {
        "refId": { "type": "string" },
        "referenceType": { "type": "string", "const": "project_document" },
        "kind": { "type": "string" },
        "contentHash": { "type": "string" },
        "uri": {
          "type": "string",
          "pattern": "^project://[^/\\\\].*$"
        },
        "claimIds": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "evidenceRefs": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    },
    "InputReference": {
      "oneOf": [
        { "$ref": "#/$defs/ArtifactInputReference" },
        { "$ref": "#/$defs/ProjectDocumentInputReference" }
      ]
    },
    "ExecutorReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["providerId", "providerVersion", "executionMode"],
      "properties": {
        "providerId": { "type": "string" },
        "providerVersion": { "type": "string" },
        "executionMode": {
          "type": "string",
          "enum": ["remote_api", "codex_cli", "local"]
        },
        "model": { "type": "string" }
      }
    },
    "StageLogSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["message", "warnings", "errors"],
      "properties": {
        "message": { "type": "string" },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        },
        "errors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "logArtifactId": { "type": "string" }
      }
    },
    "StageExecutionSnapshot": {
      "title": "StageExecutionSnapshot",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "documentType",
        "runId",
        "projectId",
        "stageId",
        "stageDefinitionVersion",
        "jobId",
        "inputHash",
        "configHash",
        "idempotencyKey",
        "inputRefs",
        "configSnapshot",
        "executor",
        "createdAt"
      ],
      "properties": {
        "schemaVersion": { "$ref": "#/$defs/SchemaVersion" },
        "documentType": { "type": "string", "const": "stage_execution_snapshot" },
        "runId": { "type": "string" },
        "projectId": { "type": "string" },
        "stageId": { "type": "string" },
        "stageDefinitionVersion": { "type": "string" },
        "jobId": { "type": "string" },
        "inputHash": { "type": "string" },
        "configHash": { "type": "string" },
        "idempotencyKey": { "type": "string" },
        "inputRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/InputReference" }
        },
        "configSnapshot": { "$ref": "#/$defs/StageConfig" },
        "executor": { "$ref": "#/$defs/ExecutorReference" },
        "createdAt": { "type": "string" }
      }
    },
    "RetryPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maxAttempts",
        "initialBackoffMs",
        "backoffMultiplier",
        "maxBackoffMs"
      ],
      "properties": {
        "maxAttempts": { "type": "integer", "minimum": 1, "maximum": 10 },
        "initialBackoffMs": {
          "type": "integer",
          "minimum": 0,
          "maximum": 86400000
        },
        "backoffMultiplier": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "maxBackoffMs": {
          "type": "integer",
          "minimum": 0,
          "maximum": 86400000
        }
      }
    },
    "JobDefinition": {
      "title": "JobDefinition",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "documentType",
        "jobId",
        "projectId",
        "jobType",
        "stageId",
        "stageRunId",
        "executionSnapshotUri",
        "idempotencyHash",
        "requestHash",
        "inputRefs",
        "executor",
        "retryPolicy",
        "createdAt"
      ],
      "properties": {
        "schemaVersion": { "$ref": "#/$defs/SchemaVersion" },
        "documentType": { "type": "string", "const": "job_definition" },
        "jobId": { "type": "string", "pattern": "^job_[0-9a-f]{64}$" },
        "projectId": { "type": "string" },
        "jobType": { "type": "string", "const": "stage_run" },
        "stageId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        "stageRunId": {
          "type": "string",
          "minLength": 5,
          "maxLength": 160,
          "pattern": "^run_[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        "executionSnapshotUri": {
          "type": "string",
          "pattern": "^runs/[A-Za-z0-9][A-Za-z0-9._-]*/run_[A-Za-z0-9][A-Za-z0-9._-]*/execution\\.json$"
        },
        "idempotencyHash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "requestHash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "requestHashVersion": { "type": "integer", "const": 2 },
        "requestReceiptHash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "inputRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/InputReference" },
          "maxItems": 256
        },
        "executor": { "$ref": "#/$defs/ExecutorReference" },
        "retryPolicy": { "$ref": "#/$defs/RetryPolicy" },
        "createdAt": { "type": "string" }
      },
      "dependentRequired": {
        "requestReceiptHash": ["requestHashVersion"]
      }
    },
    "StageRun": {
      "title": "StageRun",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "documentType",
        "runId",
        "projectId",
        "stageId",
        "stageDefinitionVersion",
        "status",
        "jobId",
        "inputHash",
        "configHash",
        "idempotencyKey",
        "inputRefs",
        "configSnapshot",
        "executor",
        "artifactIds",
        "logSummary",
        "createdAt"
      ],
      "properties": {
        "schemaVersion": { "$ref": "#/$defs/SchemaVersion" },
        "documentType": { "type": "string", "const": "stage_run" },
        "runId": { "type": "string" },
        "projectId": { "type": "string" },
        "stageId": { "type": "string" },
        "stageDefinitionVersion": { "type": "string" },
        "status": { "$ref": "#/$defs/StageRunStatus" },
        "jobId": { "type": "string" },
        "inputHash": { "type": "string" },
        "configHash": { "type": "string" },
        "idempotencyKey": { "type": "string" },
        "inputRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/InputReference" }
        },
        "configSnapshot": { "$ref": "#/$defs/StageConfig" },
        "executor": { "$ref": "#/$defs/ExecutorReference" },
        "artifactIds": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "logSummary": { "$ref": "#/$defs/StageLogSummary" },
        "supersedesRunId": { "type": "string" },
        "createdAt": { "type": "string" },
        "startedAt": { "type": "string" },
        "completedAt": { "type": "string" }
      }
    },
    "ProvenanceReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claimId", "evidenceRef"],
      "properties": {
        "claimId": { "type": "string" },
        "evidenceRef": { "type": "string" }
      }
    },
    "GeneratedArtifactSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["origin", "providerId"],
      "properties": {
        "origin": { "type": "string", "const": "generated" },
        "providerId": { "type": "string" },
        "model": { "type": "string" },
        "promptArtifactId": { "type": "string" }
      }
    },
    "ImportedArtifactSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "origin",
        "sourceUri",
        "author",
        "license",
        "attributionText",
        "sourceContentHash",
        "authorizationRecordIds"
      ],
      "properties": {
        "origin": { "type": "string", "const": "imported" },
        "sourceUri": { "type": "string" },
        "author": { "type": "string" },
        "license": { "type": "string" },
        "attributionText": { "type": "string" },
        "sourceContentHash": { "type": "string" },
        "authorizationRecordIds": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    },
    "DerivedArtifactSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["origin", "sourceArtifactIds"],
      "properties": {
        "origin": { "type": "string", "const": "derived" },
        "sourceArtifactIds": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "maxItems": 256,
          "uniqueItems": true
        }
      }
    },
    "ArtifactSource": {
      "oneOf": [
        { "$ref": "#/$defs/GeneratedArtifactSource" },
        { "$ref": "#/$defs/ImportedArtifactSource" },
        { "$ref": "#/$defs/DerivedArtifactSource" }
      ]
    },
    "GeneratedArtifactDraft": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stageId",
        "runId",
        "kind",
        "evidenceRole",
        "source",
        "provenance"
      ],
      "properties": {
        "stageId": { "type": "string", "minLength": 1, "maxLength": 160 },
        "runId": { "type": "string", "minLength": 1, "maxLength": 160 },
        "kind": { "type": "string", "minLength": 1, "maxLength": 160 },
        "mediaType": { "type": "string", "minLength": 1, "maxLength": 255 },
        "evidenceRole": {
          "type": "string",
          "enum": ["expressive_material", "non_evidence"]
        },
        "source": { "$ref": "#/$defs/GeneratedArtifactSource" },
        "provenance": {
          "type": "array",
          "items": { "$ref": "#/$defs/ProvenanceReference" }
        }
      }
    },
    "ImportedArtifactSourceDraft": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "origin",
        "sourceUri",
        "author",
        "license",
        "attributionText",
        "authorizationRecordIds"
      ],
      "properties": {
        "origin": { "type": "string", "const": "imported" },
        "sourceUri": { "type": "string" },
        "author": { "type": "string" },
        "license": { "type": "string" },
        "attributionText": { "type": "string" },
        "authorizationRecordIds": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    },
    "ImportedArtifactDraft": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stageId",
        "runId",
        "kind",
        "evidenceRole",
        "source",
        "provenance"
      ],
      "properties": {
        "stageId": { "type": "string", "minLength": 1, "maxLength": 160 },
        "runId": { "type": "string", "minLength": 1, "maxLength": 160 },
        "kind": { "type": "string", "minLength": 1, "maxLength": 160 },
        "mediaType": { "type": "string", "minLength": 1, "maxLength": 255 },
        "evidenceRole": {
          "type": "string",
          "enum": ["factual_evidence", "expressive_material", "non_evidence"]
        },
        "source": { "$ref": "#/$defs/ImportedArtifactSourceDraft" },
        "provenance": {
          "type": "array",
          "items": { "$ref": "#/$defs/ProvenanceReference" }
        }
      }
    },
    "DerivedArtifactDraft": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stageId",
        "runId",
        "kind",
        "evidenceRole",
        "source",
        "provenance"
      ],
      "properties": {
        "stageId": { "type": "string", "minLength": 1, "maxLength": 160 },
        "runId": { "type": "string", "minLength": 1, "maxLength": 160 },
        "kind": { "type": "string", "minLength": 1, "maxLength": 160 },
        "mediaType": { "type": "string", "minLength": 1, "maxLength": 255 },
        "evidenceRole": {
          "type": "string",
          "enum": ["factual_evidence", "expressive_material", "non_evidence"]
        },
        "source": { "$ref": "#/$defs/DerivedArtifactSource" },
        "provenance": {
          "type": "array",
          "items": { "$ref": "#/$defs/ProvenanceReference" }
        }
      }
    },
    "ArtifactDraft": {
      "title": "ArtifactDraft",
      "description": "Artifact Store 在计算身份、内容哈希、URI、字节数和创建时间前接收的单一来源草稿。",
      "oneOf": [
        { "$ref": "#/$defs/GeneratedArtifactDraft" },
        { "$ref": "#/$defs/ImportedArtifactDraft" },
        { "$ref": "#/$defs/DerivedArtifactDraft" }
      ]
    },
    "GeneratedArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "documentType",
        "artifactId",
        "projectId",
        "stageId",
        "runId",
        "kind",
        "uri",
        "contentHash",
        "byteLength",
        "evidenceRole",
        "source",
        "provenance",
        "createdAt"
      ],
      "properties": {
        "schemaVersion": { "$ref": "#/$defs/SchemaVersion" },
        "documentType": { "type": "string", "const": "artifact" },
        "artifactId": { "type": "string" },
        "projectId": { "type": "string" },
        "stageId": { "type": "string" },
        "runId": { "type": "string" },
        "kind": { "type": "string" },
        "uri": { "type": "string" },
        "contentHash": { "type": "string" },
        "byteLength": { "type": "integer", "minimum": 0 },
        "mediaType": { "type": "string" },
        "evidenceRole": {
          "type": "string",
          "enum": ["expressive_material", "non_evidence"]
        },
        "source": { "$ref": "#/$defs/GeneratedArtifactSource" },
        "provenance": {
          "type": "array",
          "items": { "$ref": "#/$defs/ProvenanceReference" }
        },
        "createdAt": { "type": "string" }
      }
    },
    "ImportedArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "documentType",
        "artifactId",
        "projectId",
        "stageId",
        "runId",
        "kind",
        "uri",
        "contentHash",
        "byteLength",
        "evidenceRole",
        "source",
        "provenance",
        "createdAt"
      ],
      "properties": {
        "schemaVersion": { "$ref": "#/$defs/SchemaVersion" },
        "documentType": { "type": "string", "const": "artifact" },
        "artifactId": { "type": "string" },
        "projectId": { "type": "string" },
        "stageId": { "type": "string" },
        "runId": { "type": "string" },
        "kind": { "type": "string" },
        "uri": { "type": "string" },
        "contentHash": { "type": "string" },
        "byteLength": { "type": "integer", "minimum": 0 },
        "mediaType": { "type": "string" },
        "evidenceRole": {
