{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://narracut.dev/schemas/media/v1/narracut-media-v1.schema.json",
  "title": "NarraCutMediaDocument",
  "description": "NarraCut v1 reviewed media, scene-plan, and minimal timeline contracts.",
  "oneOf": [
    { "$ref": "#/$defs/AudioMediaDocument" },
    { "$ref": "#/$defs/CaptionsMediaDocument" },
    { "$ref": "#/$defs/ScenePlanDocument" },
    { "$ref": "#/$defs/TimelineDocument" }
  ],
  "$defs": {
    "SchemaVersion": { "type": "string", "const": "1.0.0" },
    "PortableId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "RunId": {
      "type": "string",
      "minLength": 5,
      "maxLength": 160,
      "pattern": "^run_[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "ArtifactId": {
      "type": "string",
      "minLength": 10,
      "maxLength": 160,
      "pattern": "^artifact_[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "Sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "ProjectUri": {
      "type": "string",
      "pattern": "^artifacts/objects/sha256/[0-9a-f]{2}/[0-9a-f]{64}$"
    },
    "Timestamp": { "type": "string", "minLength": 20, "maxLength": 40 },
    "JsonObject": { "type": "object", "additionalProperties": true },
    "StringSet": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "maxLength": 512 },
      "maxItems": 1024,
      "uniqueItems": true
    },
    "FrozenArtifactInput": {
      "title": "FrozenArtifactInput",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "projectId",
        "stageId",
        "runId",
        "artifactId",
        "contentHash",
        "reviewRecordId",
        "claimIds",
        "evidenceRefs"
      ],
      "properties": {
        "projectId": { "$ref": "#/$defs/PortableId" },
        "stageId": { "$ref": "#/$defs/PortableId" },
        "runId": { "$ref": "#/$defs/RunId" },
        "artifactId": { "$ref": "#/$defs/ArtifactId" },
        "contentHash": { "$ref": "#/$defs/Sha256" },
        "reviewRecordId": { "$ref": "#/$defs/PortableId" },
        "claimIds": { "$ref": "#/$defs/StringSet" },
        "evidenceRefs": { "$ref": "#/$defs/StringSet" }
      }
    },
    "MediaRights": {
      "title": "MediaRights",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ownership",
        "author",
        "rightsStatement",
        "licenseId",
        "attributionText",
        "voiceAuthorization"
      ],
      "properties": {
        "ownership": { "type": "string", "enum": ["self_recorded", "licensed"] },
        "author": { "type": "string", "minLength": 1, "maxLength": 256 },
        "rightsStatement": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "licenseId": { "type": "string", "minLength": 1, "maxLength": 256 },
        "attributionText": { "type": "string", "maxLength": 2048 },
        "voiceAuthorization": { "type": "string", "const": "not_voice_clone" }
      }
    },
    "ImportedSourceIdentity": {
      "title": "ImportedSourceIdentity",
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceFileName", "sourceContentHash", "byteLength"],
      "properties": {
        "sourceFileName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255,
          "pattern": "^[^/\\\\\\u0000]+$"
        },
        "sourceContentHash": { "$ref": "#/$defs/Sha256" },
        "byteLength": { "type": "integer", "minimum": 1, "maximum": 67108864 }
      }
    },
    "AudioMediaDocument": {
      "title": "AudioMediaDocument",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "documentType",
        "mediaId",
        "projectId",
        "runId",
        "artifactUri",
        "source",
        "rights",
        "durationMs",
        "sampleRateHz",
        "bitsPerSample",
        "channels",
        "blockAlign",
        "byteRate",
        "dataBytes",
        "inputRefs",
        "configSnapshot",
        "createdAt"
      ],
      "properties": {
        "schemaVersion": { "$ref": "#/$defs/SchemaVersion" },
        "documentType": { "type": "string", "const": "audio_media" },
        "mediaId": { "$ref": "#/$defs/PortableId" },
        "projectId": { "$ref": "#/$defs/PortableId" },
        "runId": { "$ref": "#/$defs/RunId" },
        "artifactUri": { "$ref": "#/$defs/ProjectUri" },
        "source": { "$ref": "#/$defs/ImportedSourceIdentity" },
        "rights": { "$ref": "#/$defs/MediaRights" },
        "durationMs": { "type": "integer", "minimum": 1, "maximum": 86400000 },
        "sampleRateHz": { "type": "integer", "minimum": 8000, "maximum": 384000 },
        "bitsPerSample": { "type": "integer", "enum": [8, 16, 24, 32] },
        "channels": { "type": "integer", "minimum": 1, "maximum": 8 },
        "blockAlign": { "type": "integer", "minimum": 1, "maximum": 64 },
        "byteRate": { "type": "integer", "minimum": 1, "maximum": 24576000 },
        "dataBytes": { "type": "integer", "minimum": 1, "maximum": 67108864 },
        "inputRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/FrozenArtifactInput" },
          "minItems": 1,
          "maxItems": 8
        },
        "configSnapshot": { "$ref": "#/$defs/JsonObject" },
        "createdAt": { "$ref": "#/$defs/Timestamp" }
      }
    },
    "CaptionCue": {
      "title": "CaptionCue",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cueId",
        "sourceIndex",
        "startMs",
        "endMs",
        "text",
        "claimIds",
        "evidenceRefs"
      ],
      "properties": {
        "cueId": { "$ref": "#/$defs/PortableId" },
        "sourceIndex": { "type": "integer", "minimum": 1, "maximum": 10000 },
        "startMs": { "type": "integer", "minimum": 0, "maximum": 86400000 },
        "endMs": { "type": "integer", "minimum": 1, "maximum": 86400000 },
        "text": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "claimIds": { "$ref": "#/$defs/StringSet" },
        "evidenceRefs": { "$ref": "#/$defs/StringSet" }
      }
    },
    "TimingMapping": {
      "title": "TimingMapping",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mappingId",
        "level",
        "sourceCueId",
        "startMs",
        "endMs",
        "text",
        "timingPrecision",
        "timingBasis"
      ],
      "properties": {
        "mappingId": { "$ref": "#/$defs/PortableId" },
        "level": { "type": "string", "enum": ["cue", "sentence", "word"] },
        "sourceCueId": { "$ref": "#/$defs/PortableId" },
        "startMs": { "type": "integer", "minimum": 0, "maximum": 86400000 },
        "endMs": { "type": "integer", "minimum": 1, "maximum": 86400000 },
        "text": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "timingPrecision": { "type": "string", "enum": ["cue_exact", "estimated"] },
        "timingBasis": {
          "type": "string",
          "enum": ["srt_cue", "sentence_interpolation", "word_interpolation"]
        }
      }
    },
    "MediaDiagnostic": {
      "title": "MediaDiagnostic",
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "severity", "message", "blocking"],
      "properties": {
        "code": { "$ref": "#/$defs/PortableId" },
        "severity": { "type": "string", "enum": ["info", "warning", "error"] },
        "message": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "blocking": { "type": "boolean" },
        "cueId": { "$ref": "#/$defs/PortableId" },
        "sceneId": { "$ref": "#/$defs/PortableId" }
      }
    },
    "CaptionsMediaDocument": {
      "title": "CaptionsMediaDocument",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "documentType",
        "captionsId",
        "projectId",
        "runId",
        "rawArtifactId",
        "rawContentHash",
        "source",
        "audioInput",
        "cues",
        "mappings",
        "diagnostics",
        "inputRefs",
        "configSnapshot",
        "createdAt"
      ],
      "properties": {
        "schemaVersion": { "$ref": "#/$defs/SchemaVersion" },
        "documentType": { "type": "string", "const": "captions_media" },
        "captionsId": { "$ref": "#/$defs/PortableId" },
        "projectId": { "$ref": "#/$defs/PortableId" },
        "runId": { "$ref": "#/$defs/RunId" },
        "rawArtifactId": { "$ref": "#/$defs/ArtifactId" },
        "rawContentHash": { "$ref": "#/$defs/Sha256" },
        "source": { "$ref": "#/$defs/ImportedSourceIdentity" },
        "audioInput": { "$ref": "#/$defs/FrozenArtifactInput" },
        "cues": {
          "type": "array",
          "items": { "$ref": "#/$defs/CaptionCue" },
          "minItems": 1,
          "maxItems": 10000
        },
        "mappings": {
          "type": "array",
          "items": { "$ref": "#/$defs/TimingMapping" },
          "minItems": 1,
          "maxItems": 200000
        },
        "diagnostics": {
          "type": "array",
          "items": { "$ref": "#/$defs/MediaDiagnostic" },
          "maxItems": 10000
        },
        "inputRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/FrozenArtifactInput" },
          "minItems": 2,
          "maxItems": 16
        },
        "configSnapshot": { "$ref": "#/$defs/JsonObject" },
        "createdAt": { "$ref": "#/$defs/Timestamp" }
      }
    },
    "ScenePlanScene": {
      "title": "ScenePlanScene",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sceneId",
        "order",
        "title",
        "narrativeRole",
        "suggestedStartMs",
        "suggestedEndMs",
        "cueIds",
        "claimIds",
        "evidenceRefs"
      ],
      "properties": {
        "sceneId": { "$ref": "#/$defs/PortableId" },
        "order": { "type": "integer", "minimum": 0, "maximum": 9999 },
        "title": { "type": "string", "minLength": 1, "maxLength": 256 },
        "narrativeRole": { "type": "string", "minLength": 1, "maxLength": 512 },
        "suggestedStartMs": { "type": "integer", "minimum": 0, "maximum": 86400000 },
        "suggestedEndMs": { "type": "integer", "minimum": 1, "maximum": 86400000 },
        "cueIds": {
          "type": "array",
          "items": { "$ref": "#/$defs/PortableId" },
          "minItems": 1,
          "maxItems": 10000,
          "uniqueItems": true
        },
        "claimIds": { "$ref": "#/$defs/StringSet" },
        "evidenceRefs": { "$ref": "#/$defs/StringSet" }
      }
    },
    "ChangeSummary": {
      "title": "ChangeSummary",
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "changedSceneIds"],
      "properties": {
        "summary": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "changedSceneIds": {
          "type": "array",
          "items": { "$ref": "#/$defs/PortableId" },
          "maxItems": 10000,
          "uniqueItems": true
        }
      }
    },
    "ScenePlanDocument": {
      "title": "ScenePlanDocument",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "documentType",
        "scenePlanId",
        "projectId",
        "runId",
        "inputRefs",
        "configSnapshot",
        "scenes",
        "diagnostics",
        "changeSummary",
        "createdAt"
      ],
      "properties": {
        "schemaVersion": { "$ref": "#/$defs/SchemaVersion" },
        "documentType": { "type": "string", "const": "scene_plan" },
        "scenePlanId": { "$ref": "#/$defs/PortableId" },
        "projectId": { "$ref": "#/$defs/PortableId" },
        "runId": { "$ref": "#/$defs/RunId" },
        "supersedesArtifactId": { "$ref": "#/$defs/ArtifactId" },
        "inputRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/FrozenArtifactInput" },
          "minItems": 2,
          "maxItems": 32
        },
        "configSnapshot": { "$ref": "#/$defs/JsonObject" },
        "scenes": {
          "type": "array",
          "items": { "$ref": "#/$defs/ScenePlanScene" },
          "minItems": 1,
          "maxItems": 10000
        },
        "diagnostics": {
          "type": "array",
          "items": { "$ref": "#/$defs/MediaDiagnostic" },
          "maxItems": 10000
        },
        "changeSummary": { "$ref": "#/$defs/ChangeSummary" },
        "createdAt": { "$ref": "#/$defs/Timestamp" }
      }
    },
    "Canvas": {
      "title": "TimelineCanvas",
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height", "frameRateNumerator", "frameRateDenominator"],
      "properties": {
        "width": { "type": "integer", "minimum": 16, "maximum": 16384 },
        "height": { "type": "integer", "minimum": 16, "maximum": 16384 },
        "frameRateNumerator": { "type": "integer", "minimum": 1, "maximum": 240000 },
        "frameRateDenominator": { "type": "integer", "minimum": 1, "maximum": 10000 }
      }
    },
    "SafeArea": {
      "title": "TimelineSafeArea",
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": { "type": "integer", "minimum": 0, "maximum": 16384 },
        "y": { "type": "integer", "minimum": 0, "maximum": 16384 },
        "width": { "type": "integer", "minimum": 1, "maximum": 16384 },
        "height": { "type": "integer", "minimum": 1, "maximum": 16384 }
      }
    },
    "TimelineScene": {
      "title": "TimelineScene",
      "type": "object",
      "additionalProperties": false,
      "required": ["sceneId", "startMs", "endMs"],
      "properties": {
        "sceneId": { "$ref": "#/$defs/PortableId" },
        "startMs": { "type": "integer", "minimum": 0, "maximum": 86400000 },
        "endMs": { "type": "integer", "minimum": 1, "maximum": 86400000 }
      }
    },
    "AudioTrack": {
      "title": "TimelineAudioTrack",
      "type": "object",
      "additionalProperties": false,
      "required": ["audioArtifactId", "startMs", "endMs"],
      "properties": {
        "audioArtifactId": { "$ref": "#/$defs/ArtifactId" },
        "startMs": { "type": "integer", "const": 0 },
        "endMs": { "type": "integer", "minimum": 1, "maximum": 86400000 }
      }
    },
    "CaptionReferenceTrack": {
      "title": "TimelineCaptionReferenceTrack",
      "type": "object",
      "additionalProperties": false,
      "required": ["captionsArtifactId", "cueIds", "visible"],
      "properties": {
        "captionsArtifactId": { "$ref": "#/$defs/ArtifactId" },
        "cueIds": {
          "type": "array",
          "items": { "$ref": "#/$defs/PortableId" },
          "maxItems": 10000,
          "uniqueItems": true
        },
        "visible": { "type": "boolean" }
      }
    },
    "TimelineDocument": {
      "title": "TimelineDocument",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "documentType",
        "timelineId",
        "projectId",
        "runId",
        "durationMs",
        "canvas",
        "audioTrack",
        "sceneTrack",
        "captionTrack",
        "safeArea",
        "inputRefs",
        "configSnapshot",
        "changeSummary",
        "createdAt"
      ],
      "properties": {
        "schemaVersion": { "$ref": "#/$defs/SchemaVersion" },
        "documentType": { "type": "string", "const": "timeline" },
        "timelineId": { "$ref": "#/$defs/PortableId" },
        "projectId": { "$ref": "#/$defs/PortableId" },
        "runId": { "$ref": "#/$defs/RunId" },
        "supersedesArtifactId": { "$ref": "#/$defs/ArtifactId" },
        "durationMs": { "type": "integer", "minimum": 1, "maximum": 86400000 },
        "canvas": { "$ref": "#/$defs/Canvas" },
        "audioTrack": { "$ref": "#/$defs/AudioTrack" },
        "sceneTrack": {
          "type": "array",
          "items": { "$ref": "#/$defs/TimelineScene" },
          "minItems": 1,
          "maxItems": 10000
        },
        "captionTrack": { "$ref": "#/$defs/CaptionReferenceTrack" },
        "safeArea": { "$ref": "#/$defs/SafeArea" },
        "inputRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/FrozenArtifactInput" },
          "minItems": 3,
          "maxItems": 32
        },
        "configSnapshot": { "$ref": "#/$defs/JsonObject" },
        "changeSummary": { "$ref": "#/$defs/ChangeSummary" },
        "createdAt": { "$ref": "#/$defs/Timestamp" }
      }
    }
  }
}
