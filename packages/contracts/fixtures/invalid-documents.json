[
  {
    "name": "project 缺少 schemaVersion",
    "sourceDocumentType": "project",
    "patch": {
      "op": "remove",
      "path": ["schemaVersion"]
    }
  },
  {
    "name": "StageRun 使用阶段专属 stale 状态",
    "sourceDocumentType": "stage_run",
    "patch": {
      "op": "replace",
      "path": ["status"],
      "value": "stale"
    }
  },
  {
    "name": "approved 阶段缺少采用版本",
    "sourceDocumentType": "project",
    "patch": {
      "op": "remove",
      "path": ["stages", 0, "approvedRunId"]
    }
  },
  {
    "name": "stale 阶段缺少采用版本",
    "sourceDocumentType": "project",
    "patch": {
      "op": "remove",
      "path": ["stages", 1, "approvedRunId"]
    }
  },
  {
    "name": "stale 阶段没有失效来源",
    "sourceDocumentType": "project",
    "patch": {
      "op": "replace",
      "path": ["stages", 1, "staleBecauseStageIds"],
      "value": []
    }
  },
  {
    "name": "生成产物被标记为事实证据",
    "sourceDocumentType": "artifact",
    "patch": {
      "op": "replace",
      "path": ["evidenceRole"],
      "value": "factual_evidence"
    }
  },
  {
    "name": "外部素材缺少许可证",
    "sourceDocumentType": "render_manifest",
    "patch": {
      "op": "remove",
      "path": ["assets", 0, "source", "license"]
    }
  },
  {
    "name": "ReviewRecord 使用未知审核结论",
    "sourceDocumentType": "review_record",
    "patch": {
      "op": "replace",
      "path": ["decision"],
      "value": "auto_accepted"
    }
  },
  {
    "name": "JobEvent sequence 不是整数",
    "sourceDocumentType": "job_event",
    "patch": {
      "op": "replace",
      "path": ["sequence"],
      "value": "3"
    }
  },
  {
    "name": "progress 事件缺少 progress",
    "sourceDocumentType": "job_event",
    "patch": {
      "op": "remove",
      "path": ["progress"]
    }
  },
  {
    "name": "completed 事件使用 failed 状态",
    "sourceDocumentType": "job_event",
    "patches": [
      {
        "op": "replace",
        "path": ["eventType"],
        "value": "completed"
      },
      {
        "op": "replace",
        "path": ["status"],
        "value": "failed"
      },
      {
        "op": "replace",
        "path": ["progress"],
        "value": 1
      },
      {
        "op": "remove",
        "path": ["message"]
      }
    ]
  },
  {
    "name": "artifact_created 事件缺少 artifactId",
    "sourceDocumentType": "job_event",
    "patches": [
      {
        "op": "replace",
        "path": ["eventType"],
        "value": "artifact_created"
      },
      {
        "op": "remove",
        "path": ["progress"]
      },
      {
        "op": "remove",
        "path": ["message"]
      }
    ]
  },
  {
    "name": "failed 事件缺少 error",
    "sourceDocumentType": "job_event",
    "patches": [
      {
        "op": "replace",
        "path": ["eventType"],
        "value": "failed"
      },
      {
        "op": "replace",
        "path": ["status"],
        "value": "failed"
      },
      {
        "op": "remove",
        "path": ["progress"]
      },
      {
        "op": "remove",
        "path": ["message"]
      }
    ]
  },
  {
    "name": "JobEvent progress 超出范围",
    "sourceDocumentType": "job_event",
    "patch": {
      "op": "replace",
      "path": ["progress"],
      "value": 1.5
    }
  },
  {
    "name": "RenderManifest 缺少时间轴输入",
    "sourceDocumentType": "render_manifest",
    "patch": {
      "op": "remove",
      "path": ["timeline"]
    }
  },
  {
    "name": "RenderManifest 缺少音频输入",
    "sourceDocumentType": "render_manifest",
    "patch": {
      "op": "remove",
      "path": ["audio"]
    }
  },
  {
    "name": "RenderManifest 缺少字幕输入",
    "sourceDocumentType": "render_manifest",
    "patch": {
      "op": "remove",
      "path": ["captions"]
    }
  },
  {
    "name": "RenderManifest 缺少最终视频",
    "sourceDocumentType": "render_manifest",
    "patch": {
      "op": "remove",
      "path": ["videoOutput"]
    }
  },
  {
    "name": "StageExecutionSnapshot missing execution inputs",
    "sourceDocumentType": "stage_execution_snapshot",
    "patch": {
      "op": "remove",
      "path": ["inputRefs"]
    }
  },
  {
    "name": "Artifact input reference requires artifactId",
    "sourceDocumentType": "stage_run",
    "patch": {
      "op": "remove",
      "path": ["inputRefs", 0, "artifactId"]
    }
  },
  {
    "name": "Input reference discriminator is bounded",
    "sourceDocumentType": "stage_run",
    "patch": {
      "op": "replace",
      "path": ["inputRefs", 0, "referenceType"],
      "value": "shell"
    }
  }
]
