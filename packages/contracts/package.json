{
  "name": "@narracut/contracts",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./schema/narracut-contracts-v1.schema.json",
    "./project-commands-schema": "./schema/narracut-project-commands-v1.schema.json"
  },
  "scripts": {
    "build": "pnpm check:generated && tsc -p tsconfig.json --noEmit",
    "check:generated": "node scripts/generate-types.mjs --check",
    "generate": "node scripts/generate-types.mjs",
    "test": "node scripts/validate-fixtures.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "ajv": "8.20.0",
    "json-schema-to-typescript": "15.0.4",
    "typescript": "~5.8.3"
  }
}
