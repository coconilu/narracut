{
  "name": "narracut-workspace",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@11.7.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @narracut/desktop tauri dev",
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r --if-present typecheck",
    "check": "pnpm typecheck && cargo check --workspace",
    "test": "cargo test --workspace",
    "tauri": "pnpm --filter @narracut/desktop tauri"
  }
}
